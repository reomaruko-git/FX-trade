# .env.example
# このファイルをコピーして ".env" にリネームし、実際の値を入力してください。
# .env は絶対にGitにコミットしないでください（.gitignore に追加済み）。

# ── OANDA（本番モード時に必要） ──────────────────────────────
OANDA_API_KEY=your_api_key_here
OANDA_ACCOUNT_ID=001-009-XXXXXXX-XXX
OANDA_ENVIRONMENT=practice          # practice（デモ）or live（本番）

# ── LINE Messaging API ────────────────────────────────────────
LINE_CHANNEL_TOKEN=your_channel_access_token_here
# グループIDの取得: ボットをグループに招待 → webhook.siteでgroupIdを確認
# グループIDは "C" で始まる（例: C1234567890abcdef1234567890abcdef）
LINE_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 運用設定 ──────────────────────────────────────────────────
INITIAL_BALANCE=1000000     # 初期資金（円）
DRY_RUN=true                # true=シグナル通知のみ / false=OANDA発注あり
LOOP_SEC=300                # チェック間隔（秒）
LOT=1000                    # 発注ロット（通貨単位）

# ── 動作パラメータ（省略可・デフォルト値あり） ────────────────
MAX_RETRY=3                 # APIリトライ回数
SMA_PERIOD=200              # トレンドフィルター用SMA期間
SPREAD_PIPS=0.4             # スプレッド基準値
